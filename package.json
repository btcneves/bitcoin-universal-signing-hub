{
  "name": "bitcoin-universal-recovery-signing-hub",
  "private": true,
  "version": "0.1.0",
  "description": "Offline-first Bitcoin recovery and signing platform",
  "scripts": {
    "build": "node scripts/run-workspaces.mjs build",
    "dev": "node scripts/run-workspaces.mjs dev",
    "lint": "node scripts/run-workspaces.mjs lint",
    "test": "node scripts/run-workspaces.mjs test",
    "typecheck": "node scripts/run-workspaces.mjs typecheck",
    "format": "prettier --write .",
    "prepare": "husky",
    "install:ci": "pnpm install --frozen-lockfile=false",
    "validate:ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "usb:prepare-web": "bash infra/usb/scripts/prepare-web-bundle.sh",
    "usb:build-iso": "bash infra/usb/scripts/build-iso.sh"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-security": "^3.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=20.19 <23",
    "pnpm": ">=10.13.1",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "infra/*"
  ]
}
