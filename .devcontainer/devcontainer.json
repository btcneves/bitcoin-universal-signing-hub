{
  "name": "bursh-dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "remoteUser": "node",
  "postCreateCommand": "pnpm run install:ci",
  "postStartCommand": "echo 'Validation command: pnpm run validate:ci'",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
